# Dependencies - downloaded packages (can be reinstalled with npm install)
node_modules/

# Environment variables - YOUR SECRET API KEYS! Never commit this!
.env
.env.local
.env.*.local

# Expo build files - generated during builds
.expo/
dist/
web-build/

# Native builds - generated when building for iOS/Android
ios/
android/

# Mac system files
.DS_Store

# Editor settings (optional - some teams share these)
.vscode/
.idea/

# TypeScript cache
*.tsbuildinfo

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
